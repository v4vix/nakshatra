# ─── Nakshatra Backend — Environment Variables ────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Server ──
PORT=3001
NODE_ENV=development

# ── Security ──
ADMIN_TOKEN=nakshatra-admin-secret
CORS_ORIGIN=http://localhost:5173

# ── AI / LLM ──
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Payments (RevenueCat Server-Side) ──
# Get from RevenueCat Dashboard → API Keys → Secret key (sk_xxxx)
REVENUECAT_API_KEY=

# ── Error Tracking ──
SENTRY_DSN=

# ── Database (future — currently using file-based storage) ──
# DATABASE_URL=postgresql://user:pass@host:5432/nakshatra
