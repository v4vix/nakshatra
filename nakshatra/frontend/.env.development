# ─── Development Environment Variables ────────────────────────────────────────

# Local backend (Vite proxy handles /api/* → localhost:3001)
VITE_API_URL=http://localhost:3001/api/v1

# Dev admin token
VITE_ADMIN_TOKEN=nakshatra-admin-secret

# RevenueCat — not needed in dev (IAP only works on device)
VITE_REVENUECAT_KEY=

# PostHog — disabled in dev (isDev check skips init)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Sentry — disabled in dev
VITE_SENTRY_DSN=
